{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "you-ai",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "routes": [
    { "pattern": "you-ai.io", "custom_domain": true },
    { "pattern": "www.you-ai.io", "custom_domain": true }
  ]
}
